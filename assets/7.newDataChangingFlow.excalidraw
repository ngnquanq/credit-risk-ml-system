    {
      "id": "T0bf02WhSiU6wKdb4sDv4",
      "type": "text",
      "x": 1489.314731891914,
      "y": 624.0732370440792,
      "width": 448.5609130859375,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4c",
      "roundness": null,
      "seed": 1098847342,
      "version": 447,
      "versionNonce": 845932978,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1757222623474,
      "link": null,
      "locked": false,
      "text": "Notice:\n- staging and prod is not strictly related to the \nstaging and production environment.\n- the meaning is relatively not strictly, i.e:\n    -> if we move data from ops-db to dwh, then\n    the ops-db is the staging and the dwh is the prod\n    -> if we move data from dwh to data-mart, then\n    the dwh is the staging and the data-mart is the prod",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Notice:\n- staging and prod is not strictly related to the \nstaging and production environment.\n- the meaning is relatively not strictly, i.e:\n    -> if we move data from ops-db to dwh, then\n    the ops-db is the staging and the dwh is the prod\n    -> if we move data from dwh to data-mart, then\n    the dwh is the staging and the data-mart is the prod",
      "autoResize": true,
      "lineHeight": 1.25
    },
