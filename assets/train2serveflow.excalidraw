      "link": null,
      "locked": false,
      "text": "Sync feature registry \nwith Object Storage",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "FNSRWnKweZhUVptaQfvjP",
      "originalText": "Sync feature registry \nwith Object Storage",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "nqOOD-4us4zDViUzZyYlN",
      "type": "text",
      "x": 796.219392642033,
      "y": 966.0300028372085,
      "width": 520.7689819335938,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1X",
      "roundness": null,
      "seed": 1740209956,
      "version": 306,
      "versionNonce": 1206917595,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1760768914833,
      "link": null,
      "locked": false,
      "text": "feature_metadata (in training): feature that was used to train\nfeast_metadata (in inference): feature that was available in feast\n=> We check if are there any missing feature so that we can \nmonitoring things easier",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "feature_metadata (in training): feature that was used to train\nfeast_metadata (in inference): feature that was available in feast\n=> We check if are there any missing feature so that we can \nmonitoring things easier",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MUCwEmkgwMH2IROUvpQOb",
      "type": "text",
      "x": 95.38627851264081,
      "y": 569.6011237765849,
      "width": 404.0968017578125,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Y",
      "roundness": null,
      "seed": 1653470235,
      "version": 231,
      "versionNonce": 690991445,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1760768920549,
      "link": null,
      "locked": false,
      "text": "The reason for sync to object storage instead\nof using a PVC dedicate to store feature registry\nis for easier auditing, i.e each version get their own\nfeast registry. ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The reason for sync to object storage instead\nof using a PVC dedicate to store feature registry\nis for easier auditing, i.e each version get their own\nfeast registry. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
