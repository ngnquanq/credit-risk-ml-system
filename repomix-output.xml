from pydantic_settings import BaseSettings
try:
    from application.core.config import settings as app_settings
except Exception:
    app_settings = None
class ScoringSettings(BaseSettings):
    model_config = ConfigDict(
        env_prefix="SCORING_",
        env_file="mlflow.env",
