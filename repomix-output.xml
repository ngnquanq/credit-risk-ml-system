        except bentoml.exceptions.BentoMLException as e:
            logger.warning(f"Feature fetch failed for {sk_id_curr}: {e}")
            return {
                "sk_id_curr": sk_id_curr,
                "probability": None,
                "decision": "under-review",
                "threshold": settings.prediction_threshold,
                "model": MODEL_NAME,
