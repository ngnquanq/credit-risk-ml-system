from __future__ import annotations
from typing import Dict, Any, Optional, List
from datetime import datetime
import json
import threading
import os
import tempfile
from concurrent.futures import ThreadPoolExecutor
import bentoml
svc = bentoml.Service("credit_risk_scoring")
app = None
logger = None
pd = None
settings = None
ScoreRequest = None
ScoreResponse = None
