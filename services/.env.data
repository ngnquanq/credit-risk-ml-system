# Data Platform Environment Variables
# ===================================

# MinIO Storage Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=${DEFAULT_PASSWORD:-minioadmin}
MINIO_DOMAIN=localhost
MINIO_BROWSER_REDIRECT_URL=http://localhost:${MINIO_CONSOLE_PORT}

# ClickHouse Data Warehouse
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_MAX_CONNECTIONS=4096
CLICKHOUSE_MAX_MEMORY_USAGE=20000000000

# HyperDX Configuration
HDX_IMAGE_REPO=hyperdx
IMAGE_NAME_DOCKERHUB=hyperdx
OTEL_COLLECTOR_IMAGE_NAME_DOCKERHUB=hyperdx-otel-collector
IMAGE_VERSION=latest
HYPERDX_API_KEY=hdx_changeme_api_key
HYPERDX_API_PORT=8000
HYPERDX_APP_PORT=8080
HYPERDX_APP_URL=http://localhost
HYPERDX_OPAMP_PORT=8088
HYPERDX_LOG_LEVEL=info
HYPERDX_OTEL_EXPORTER_CLICKHOUSE_DATABASE=default
USAGE_STATS_ENABLED=true

# MongoDB (HyperDX)
MONGO_URI=mongodb://db:27017/hyperdx

# Kafka Streaming Configuration
KAFKA_VERSION=7.4.0
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_EXTERNAL_PORT=9092
KAFKA_INTERNAL_PORT=29092
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_NUM_PARTITIONS=3
KAFKA_DEFAULT_REPLICATION_FACTOR=1
KAFKA_CLUSTER_NAME=hc-local

# Kafka UI Configuration
KAFKA_UI_VERSION=latest
KAFKA_UI_PORT=8082

# Schema Registry Configuration
SCHEMA_REGISTRY_PORT=8081

# Zookeeper Configuration
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

# CDC/Debezium Configuration
DEBEZIUM_VERSION=1.9
DEBEZIUM_UI_VERSION=latest
DEBEZIUM_PORT=8083
DEBEZIUM_UI_PORT=8080
DEBEZIUM_GROUP_ID=1
DEBEZIUM_CONFIG_TOPIC=connect_configs
DEBEZIUM_OFFSET_TOPIC=connect_offsets
SCHEMA_REGISTRY_URL=http://schema-registry:${SCHEMA_REGISTRY_PORT:-8081}

# CDC Topic Configuration
CDC_TOPIC_PREFIX=hc.applications
CDC_PUBLICATION_NAME=debezium_pub
CDC_SLOT_NAME=debezium_slot
CDC_CONNECTOR_NAME=postgres-application-connector
CDC_PLUGIN_NAME=pgoutput
CDC_SNAPSHOT_MODE=initial

# Apache Spark Configuration
SPARK_VERSION=3.4.1
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=8084
SPARK_MASTER_MEMORY=1g
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g

# Spark Workers Configuration
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g
SPARK_WORKER_DAEMON_MEMORY=1g
SPARK_WORKER_1_WEBUI_PORT=8085
SPARK_WORKER_1_PORT=8881
SPARK_WORKER_2_WEBUI_PORT=8086
SPARK_WORKER_2_PORT=8882

# Spark History Server
SPARK_HISTORY_WEBUI_PORT=18080
SPARK_HISTORY_RETAINED_APPS=50
SPARK_HISTORY_MAX_APPS=50
SPARK_HISTORY_MEMORY=1g

# Jupyter with PySpark
JUPYTER_VERSION=spark-3.4.1
JUPYTER_PORT=8888
JUPYTER_TOKEN=spark_notebook_token
JUPYTER_SPARK_DRIVER_MEMORY=1g
JUPYTER_SPARK_EXECUTOR_MEMORY=1g
JUPYTER_SPARK_UI_PORT=4040