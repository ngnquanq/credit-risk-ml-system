# ===============================================================
# Home Credit ML Platform - Environment Configuration Template
# ===============================================================
# 
# Copy this file to .env and customize the values for your environment
# For platform-specific overrides, also copy the respective:
# - .env.core.template → .env.core
# - .env.data.template → .env.data  
# - .env.ml.template → .env.ml
# - .env.ops.template → .env.ops

# =================
# NETWORK & GLOBAL
# =================
NETWORK_NAME=hc-network

# ===============
# PORT MAPPINGS
# ===============
# Core Services
OPS_POSTGRES_PORT=5434              # Operational database port (avoid 5432 conflict)
PGBOUNCER_PORT=6432                 # Connection pooler port

# Data Platform Ports
MINIO_API_PORT=9000                 # MinIO S3 API
MINIO_CONSOLE_PORT=9001             # MinIO web console
CLICKHOUSE_HTTP_PORT=8123           # ClickHouse HTTP interface
CLICKHOUSE_NATIVE_PORT=9004         # ClickHouse native protocol

# Streaming Platform Ports
KAFKA_EXTERNAL_PORT=9092            # Kafka external access
KAFKA_INTERNAL_PORT=29092           # Kafka internal container communication
ZOOKEEPER_CLIENT_PORT=2181          # Zookeeper client port
SCHEMA_REGISTRY_PORT=8081           # Schema registry
KAFKA_UI_PORT=8082                  # Kafka management UI
DEBEZIUM_PORT=8083                  # Debezium CDC connector
DEBEZIUM_UI_PORT=8080               # Debezium management UI

# ML Platform Ports
MLFLOW_PORT=5000                    # MLflow tracking server
MLFLOW_MINIO_API_PORT=9002          # MLflow MinIO API
MLFLOW_MINIO_CONSOLE_PORT=9003      # MLflow MinIO console
FEAST_REDIS_PORT=6379               # Feast Redis online store
FEAST_SERVER_PORT=6566              # Feast feature server
BENTO_SERVING_PORT=3000             # BentoML model serving

# Operations Ports
SUPERSET_PORT=8089                  # Superset dashboard
API_GATEWAY_PORT=7000               # API gateway
GRAFANA_PORT=3000                   # Grafana monitoring (if enabled)

# ================
# SECURITY CONFIG
# ================
# ⚠️  IMPORTANT: Change these in production!
DEFAULT_PASSWORD=changeme123        # Default password for non-critical services
SECURE_PASSWORD=secure_changeme_456 # Secure password for critical services

# Individual service passwords (override DEFAULT_PASSWORD if needed)
OPS_DB_PASSWORD=${SECURE_PASSWORD}
MLFLOW_DB_PASSWORD=${DEFAULT_PASSWORD}
SUPERSET_DB_PASSWORD=${DEFAULT_PASSWORD}
MINIO_ROOT_PASSWORD=${DEFAULT_PASSWORD}
MLFLOW_MINIO_PASSWORD=${DEFAULT_PASSWORD}
GRAFANA_ADMIN_PASSWORD=${SECURE_PASSWORD}

# ===================
# DATABASE VERSIONS
# ===================
POSTGRES_VERSION=15-alpine          # PostgreSQL version for all databases
MONGO_VERSION=5.0.14-focal          # MongoDB version (HyperDX)
REDIS_VERSION=7-alpine              # Redis version for caching/features
CLICKHOUSE_VERSION=25.6-alpine      # ClickHouse version

# ================
# ML VERSIONS
# ================
MLFLOW_VERSION=v3.1.1               # MLflow version
SUPERSET_TAG=latest-dev              # Superset version

# ====================
# RESOURCE LIMITS
# ====================
# Default Docker resource limits for services
DEFAULT_MEMORY_LIMIT=2G             # Default memory limit
DEFAULT_CPU_LIMIT=1.5               # Default CPU limit
DEFAULT_MEMORY_RESERVATION=1G       # Default memory reservation
DEFAULT_CPU_RESERVATION=0.5         # Default CPU reservation

# ========================
# CORE DATABASE CONFIG
# ========================
OPS_DB_NAME=operations
OPS_DB_USER=ops_admin
OPS_DB_HOST=ops-postgres
OPS_DB_PORT=5432

# PostgreSQL performance tuning
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=128MB
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_WAL_LEVEL=replica

# PgBouncer connection pooling
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=25

# ========================
# DATA PLATFORM CONFIG
# ========================
# MinIO Object Storage
MINIO_ROOT_USER=minioadmin
MINIO_DOMAIN=localhost

# ClickHouse Data Warehouse
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=                # Empty for default setup
CLICKHOUSE_DATABASE=default

# Kafka Streaming Platform
KAFKA_VERSION=7.4.0                 # Confluent Platform version
KAFKA_BROKER_ID=1
KAFKA_CLUSTER_NAME=hc-local
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_NUM_PARTITIONS=3
KAFKA_DEFAULT_REPLICATION_FACTOR=1
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

# Zookeeper Configuration
ZOOKEEPER_TICK_TIME=2000

# Kafka UI Management
KAFKA_UI_VERSION=latest

# CDC/Change Data Capture (Debezium)
DEBEZIUM_VERSION=1.9
DEBEZIUM_UI_VERSION=latest
DEBEZIUM_GROUP_ID=1
DEBEZIUM_CONFIG_TOPIC=connect_configs
DEBEZIUM_OFFSET_TOPIC=connect_offsets
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# HyperDX Observability Platform
HDX_IMAGE_REPO=hyperdx
IMAGE_NAME_DOCKERHUB=hyperdx
OTEL_COLLECTOR_IMAGE_NAME_DOCKERHUB=hyperdx-otel-collector
IMAGE_VERSION=latest
HYPERDX_API_KEY=hdx_changeme_api_key
HYPERDX_API_PORT=8000
HYPERDX_APP_PORT=8080
HYPERDX_APP_URL=http://localhost
HYPERDX_OPAMP_PORT=8088
HYPERDX_LOG_LEVEL=info
HYPERDX_OTEL_EXPORTER_CLICKHOUSE_DATABASE=default
USAGE_STATS_ENABLED=true
MONGO_URI=mongodb://db:27017/hyperdx

# ====================
# ML PLATFORM CONFIG
# ====================
# MLflow Model Registry
MLFLOW_DB_NAME=mlflow_db
MLFLOW_DB_USER=mlflow_user
MLFLOW_TRACKING_URI=http://mlflow-server:5000
MLFLOW_BACKEND_STORE_URI=postgresql://${MLFLOW_DB_USER}:${MLFLOW_DB_PASSWORD}@mlflow-db:5432/${MLFLOW_DB_NAME}
MLFLOW_ARTIFACT_URI=s3://mlflow-artifacts/
MLFLOW_S3_ENDPOINT_URL=http://mlflow-minio:9000
MLFLOW_MINIO_USER=minio_user

# Feast Feature Store
FEAST_CONFIG_BASE64=                # Base64 encoded feast config (optional)
FEAST_TELEMETRY=false
FEAST_USAGE_STATS=false
FEAST_S3_BUCKET=feast-registry
FEAST_BATCH_SIZE=10000
FEAST_BATCH_CRON=0 */2 * * *        # Every 2 hours

# Redis Online Store for Features
REDIS_HOST=feast-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_MEMORY=1gb
REDIS_MAX_MEMORY_POLICY=allkeys-lru

# ClickHouse Offline Store
CLICKHOUSE_HOST=clickhouse_dwh
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=ml_data_mart

# BentoML Model Serving
MODEL_NAME=credit_risk_model
MODEL_VERSION=latest
PREDICTION_THRESHOLD=0.5
BENTOML_PORT=3000
BENTOML_HOST=0.0.0.0
BENTOML_WORKERS=4
BENTOML_TIMEOUT=30
BENTOML_LOG_LEVEL=info
ENABLE_FEATURE_LOGGING=true
ENABLE_PREDICTION_CACHING=true

# Service Discovery URLs
FEAST_FEATURE_SERVER_URL=http://feast-server:6566
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

# ========================
# OPERATIONS CONFIG
# ========================
# Superset Dashboard
SUPERSET_LOG_LEVEL=info
SUPERSET_LOAD_EXAMPLES=yes
SUPERSET_SECRET_KEY=changeme_superset_secret_key_production
SUPERSET_DB_HOST=db
SUPERSET_DB_PORT=5432
SUPERSET_DB_NAME=superset
SUPERSET_DB_USER=superset
SUPERSET_REDIS_PASSWORD=

# API Gateway (Nginx)
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024
NGINX_CLIENT_MAX_BODY_SIZE=100M
NGINX_PROXY_CONNECT_TIMEOUT=60s
NGINX_PROXY_SEND_TIMEOUT=60s
NGINX_PROXY_READ_TIMEOUT=60s

# Service URLs for routing
CREDIT_RISK_SERVICE_URL=http://credit-risk-service:3000
FEAST_SERVER_URL=http://feast-server:6566
SUPERSET_URL=http://superset:8088
MLFLOW_URL=http://mlflow-server:5000

# Monitoring (if enabled)
GRAFANA_ADMIN_USER=admin
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s

# ========================
# ENVIRONMENT OVERRIDES
# ========================
# You can override any variable above by environment
# Example: export OPS_DB_PASSWORD="production_password"
# 
# Or create environment-specific files:
# - .env.development
# - .env.staging  
# - .env.production